# Backend Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL connection string
LMS_DATABASE_URL=postgresql+asyncpg://lms:lms_secret@localhost:5433/lms

# CORS allowed origins (comma-separated)
LMS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Telegram Bot (optional - for task notifications)
LMS_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
LMS_TELEGRAM_CHAT_ID=your_telegram_chat_id

# AWS S3 (optional - for file storage)
LMS_AWS_ACCESS_KEY_ID=your_aws_access_key_id
LMS_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
LMS_AWS_REGION=us-east-1
LMS_AWS_BUCKET_NAME=your_bucket_name
